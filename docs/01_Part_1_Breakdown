    "# Part 1: SpLR_V2 & The Entropy Function\n",
    "# The custom Activation Function breakdown\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0cb65cda",
   "metadata": {},
   "outputs": [],
   "source": [
    "def __init__(self, channels):\n",
    "    super().__init__()\n",
    "    self.a = nn.Parameter(torch.ones(1, channels, 1, 1) * 1.1)\n",
    "    self.b = nn.Parameter(torch.ones(1, channels, 1, 1) * 0.5)\n",
    "    self.c = nn.Parameter(torch.ones(1, channels, 1, 1) * 0.1)"
   ]
  },
